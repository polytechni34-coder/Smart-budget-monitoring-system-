<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:paddingTop="24dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@null"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Peer Comparison"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/textColorPrimary"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1 — Invite Code Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorSurface"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YOUR INVITE CODE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/textColorSecondary"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:id="@+id/tvInviteCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.25"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— or connect with a friend's code —"
                        android:textSize="11sp"
                        android:textColor="@color/textColorSecondary"
                        android:layout_gravity="center"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etPeerCode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Enter friend's 6-char code"
                            android:background="@drawable/bg_dark_field"
                            android:textColor="@color/textColorPrimary"
                            android:padding="12dp"
                            android:inputType="textCapCharacters"
                            android:maxLength="8" />

                        <Button
                            android:id="@+id/btnConnect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connect"
                            android:background="@drawable/bg_gradient_button"
                            android:textColor="#FFFFFF"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvConnectStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section — Connected Peers -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connected Peers"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPeers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvNoPeers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No peers connected yet.\nShare your code with friends!"
                android:gravity="center"
                android:textColor="@color/textColorSecondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <!-- Toggle — Month / Week -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnToggleMonth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="This Month"
                    android:background="@drawable/bg_chip_selected"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btnToggleWeek"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="This Week"
                    android:background="@drawable/bg_chip_default"
                    android:textColor="@color/textColorSecondary" />
            </LinearLayout>

            <!-- Section — Comparison -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spending Comparison"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvComparison"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvNoComparison"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connect with peers to see comparison here!"
                android:gravity="center"
                android:textColor="@color/textColorSecondary"
                android:textSize="13sp"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>