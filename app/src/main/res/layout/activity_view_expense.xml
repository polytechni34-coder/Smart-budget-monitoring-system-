<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Budget Progress Bar at the top -->
            <RelativeLayout
                android:id="@+id/budgetInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:padding="12dp"
                android:background="@drawable/bg_budget_progress">

                <TextView
                    android:id="@+id/tvBudgetAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Budget: ₹0"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvTotalSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spent: ₹0"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvRemainingAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Remaining Balance"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentTop="true"/>

                <ProgressBar
                    android:id="@+id/budgetProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_below="@id/tvRemainingAmount"
                    android:layout_marginTop="10dp"
                    android:progressDrawable="@drawable/custom_progress_bar"/>

            </RelativeLayout>

            <!-- Bar Chart Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category Spending"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="4dp"/>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:textColor="#333333"/>

            <!-- Category Grid -->
            <GridLayout
                android:id="@+id/categoryGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="5"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnBills"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="🏠 Bills"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnFood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="🍔 Food"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnShopping"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="🛒 Shopping"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnTransport"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="🚌 Transport"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnEntertainment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="🎬 Entertainment"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnHealth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="🏥 Health"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnEducation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="🎓 Education"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnGifts"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="🎁 Gifts"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnTravel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="✈ Travel"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

                <Button
                    android:id="@+id/btnOther"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="📦 Other"
                    android:textAllCaps="false"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#333333"/>

            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Expenses"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:textColor="#333333"/>

            <ListView
                android:id="@+id/lvExpenses"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:nestedScrollingEnabled="true"
                android:divider="@null"
                android:dividerHeight="0dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        app:elevation="8dp"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>