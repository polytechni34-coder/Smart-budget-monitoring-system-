<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
<uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartBudgetMonitoringSystem">
        <activity
            android:name=".AnalyticsActivity"
            android:exported="false"
            android:label="Analytics" />
        <activity
            android:name=".PeerComparisonActivity"
            android:exported="false"
            android:label="Peer Comparison"
            android:parentActivityName=".DashboardActivity"/>
        <activity
            android:name=".NotificationsActivity"
            android:exported="false"
            android:label="Notifications" />
        <activity
            android:name=".EditProfileActivity"
            android:exported="false"
            android:label="Edit Profile" />
        <activity
            android:name=".ChangePasswordActivity"
            android:exported="false"
            android:label="Change Password" />
        <activity
            android:name=".CategoryExpensesActivity"
            android:exported="false" />
        <activity
            android:name=".CategoryItemsActivity"
            android:exported="false" />
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".ViewExpenseActivity"
            android:exported="false" />
        <activity
            android:name=".AddExpenseActivity"
            android:exported="false" />
        <activity
            android:name=".DashboardActivity"
            android:exported="false"
            android:label="Dashboard" />

        <activity
            android:name=".SignupActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
